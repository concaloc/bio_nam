---

<div class="min-h-screen flex items-center justify-center px-4 py-16">
  <div class="w-full max-w-md">
    <!-- Avatar + Name -->
    <SectionReveal>
      <PlaceholderAvatar size={140} class="mb-6" />
    </SectionReveal>

    <SectionReveal delay={1}>
      <div class="text-center mb-2">
        <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight rainbow-text neon-glow">
          Your Name
        </h1>
        <p class="text-white/60 text-sm mt-1 font-medium">@yourhandle</p>
      </div>
    </SectionReveal>

    <SectionReveal delay={2}>
      <p class="text-center text-white/80 text-sm md:text-base leading-relaxed mb-8 max-w-xs mx-auto">
        Building things with code. Lover of clean design, open source, and late-night debugging sessions.
      </p>
    </SectionReveal>

    <!-- Social Icons Row -->
    <SectionReveal delay={2}>
      <div class="flex justify-center gap-3 mb-8">
        {socials.map(s => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="p-3 glass rounded-full glass-hover bouncy transition-all duration-300"
          >
            <svg class="w-5 h-5 text-white/90" fill="currentColor" viewBox="0 0 24 24">
              <path d={s.icon} />
            </svg>
          </a>
        ))}
      </div>
    </SectionReveal>

    <!-- Main Links -->
    <SectionReveal delay={3}>
      <div class="space-y-3">
        {links.map((link, i) => (
          <a
            href={link.href}
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="link-card glass glass-hover flex items-center gap-4 px-5 py-4 rounded-2xl transition-all duration-300"
          >
            <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d={link.icon} />
              </svg>
            </div>
            <span class="text-white font-semibold text-sm">{link.label}</span>
            <svg class="w-4 h-4 text-white/40 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          </a>
        ))}
      </div>
    </SectionReveal>

    <!-- Footer -->
    <SectionReveal delay={4}>
      <p class="text-center text-white/30 text-xs mt-8">
        Made with Astro + Tailwind CSS
      </p>
    </SectionReveal>
  </div>
</div>
