---
interface Props {
  size?: number;
  class?: string;
}

const { size = 140, class: className = '' } = Astro.props;
---

<div class:list={["relative mx-auto avatar-ring", className]} style={`width: ${size}px; height: ${size}px;`}>
  <div class="w-full h-full rounded-full overflow-hidden glass flex items-center justify-center">
    <svg class="w-1/2 h-1/2 text-white/60" fill="currentColor" viewBox="0 0 24 24">
      <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
    </svg>
  </div>
</div>
